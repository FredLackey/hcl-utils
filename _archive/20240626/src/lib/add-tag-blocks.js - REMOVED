const _ = require('cleaner-node');
const isGoogle = require('../utils/is-google');
const toNodeList = require('../utils/to-node-list');
const isMissingTags = require('../utils/is-missing-tags');
const findNodePositions = require('../utils/find-node-positions');

const addTagBlocks = (doc) => {

  const nodes = toNodeList(doc).filter(isMissingTags);
  if (nodes.length === 0) {
    return;
  }

  const tagBlock = isGoogle(doc) ? 'labels' : 'tags';
  const tagLines = [
    `  ${tagBlock} = {`,
    `  }`
  ];

  nodes.forEach(node => {

    if (_.isValidArray(node.tagLines, true)) {
      throw new Error(`Node already has tag lines: ${node.name.value}`);
    }

    node.tagLines = [...tagLines];
  
    const lastNodeLine = node.lines[node.lines.length - 1];

    node.lines.push(tagLines);
    node.lines.push(lastNodeLine);
    node.hash = _.hashLines(node.lines);

    // Modify the document itself
    const { start, end } = findNodePositions(doc, lastNodeLine);
    const prefix = doc.lines.slice(0, start - 1); // Get all lines prior to the start position
    const suffix = doc.lines.slice(end + 1); // Get all lines after the end position

    // Create the new lines array
    doc.lines = [...prefix, ...node.lines, ...suffix];

  });

  // Ensure the document hash is up to date
  doc.hash = _.hashLines(doc.lines);

}

module.exports = addTagBlocks;